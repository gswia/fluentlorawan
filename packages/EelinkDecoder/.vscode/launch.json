{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/bin/Debug/net8.0/EelinkDecoder.dll",
            "args": ["${input:hexPayload}"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        }
    ],
    "inputs": [
        {
            "id": "hexPayload",
            "type": "promptString",
            "description": "Enter hex payload to decode",
            "default": "676714003F001169C870AD73051EBD6FF2E385C90026000D00470D013701E0000C00002827371860418D69BCB41A60419D69BCB420A6CD2C0B62B2820609000D0000000A"
        }
    ]
}
